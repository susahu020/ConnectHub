datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum NotificationType {
  TASK_ASSIGNED
  MESSAGE
  ANNOUNCEMENT
  MENTION
  REMINDER
  SYSTEM
}

enum GroupType {
  DEPARTMENT
  PROJECT
  CUSTOM
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  designation  String?
  bio          String?
  skills       String[]
  avatarUrl    String?
  role         Role     @default(EMPLOYEE)
  status       String   @default("OFFLINE")
  location     String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employeeId       String?   @unique
  coverUrl         String?
  joiningDate      DateTime?
  employmentType   String?
  officeLocation   String?
  emergencyContact String?
  birthday         DateTime?
  timezone         String    @default("UTC")
  workingHours     String?
  managerId        String?
  manager          User?     @relation("OrgStructure", fields: [managerId], references: [id], onDelete: SetNull)
  directReports    User[]    @relation("OrgStructure")
  socialLinks      Json?
  lastSeen         DateTime?
  lastLoginAt      DateTime?

  experiences    Experience[]
  educations     Education[]
  certifications Certification[]
  userSkills     UserSkill[]

  managedDepartments Department[] @relation("DepartmentManager")
  departmentId       String?
  department         Department?  @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)

  teamMemberships      TeamMember[]
  groupMemberships     GroupMember[]
  sentMessages         Message[]               @relation("MessageSender")
  receivedMessages     Message[]               @relation("MessageReceiver")
  messageStatuses      MessageStatus[]
  messageReactions     MessageReaction[]
  uploadedFiles        File[]
  createdGroups        Group[]                 @relation("GroupCreator")
  announcements        Announcement[]          @relation("AnnouncementCreator")
  comments             AnnouncementComment[]
  likes                AnnouncementLike[]
  assignedTasks        Task[]                  @relation("TaskAssignee")
  createdTasks         Task[]                  @relation("TaskCreator")
  taskComments         TaskComment[]
  taskHistories        TaskHistory[]
  notifications        Notification[]
  sessions             Session[]
  refreshTokens        RefreshToken[]
  passwordResets       PasswordReset[]
  emailVerifications   EmailVerification[]
  auditLogs            AuditLog[]
  activityLogs         ActivityLog[]
  settings             UserSettings?
  customRoleId         String?
  customRole           CustomRole?             @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  dashboardLayouts     DashboardWidgetLayout[]
  messageBookmarks     MessageBookmark[]
  messagePollVotes     MessagePollVote[]
  fileShares           FileShare[]
  taskTimeLogs         TaskTimeLog[]
  twoFactorSecret      String?
  twoFactorEnabled     Boolean                 @default(false)
  twoFactorBackupCodes String?
  loginAttempts        Int                     @default(0)
  lockoutUntil         DateTime?
  deletedConversations DeletedConversation[]
}

model Department {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String?
  managerId     String?
  manager       User?          @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees     User[]         @relation("DepartmentEmployees")
  teams         Team[]
  groups        Group[]
  announcements Announcement[]
  tasks         Task[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Team {
  id           String       @id @default(uuid())
  name         String
  description  String?
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  projects     Project[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status      String    @default("PLANNING")
  startDate   DateTime?
  endDate     DateTime?
  groups      Group[]
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Group {
  id           String        @id @default(uuid())
  name         String
  description  String?
  type         GroupType     @default(CUSTOM)
  isBroadcast  Boolean       @default(false)
  avatarUrl    String?
  createdById  String
  creator      User          @relation("GroupCreator", fields: [createdById], references: [id])
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members      GroupMember[]
  messages     Message[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model Message {
  id                   String      @id @default(uuid())
  groupId              String?
  group                Group?      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId             String
  sender               User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId           String?
  receiver             User?       @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content              String
  type                 MessageType @default(TEXT)
  isEdited             Boolean     @default(false)
  isDeleted            Boolean     @default(false)
  isPinned             Boolean     @default(false)
  forwardedFromId      String? // Tracks parent/source message when forwarded
  isDeletedForEveryone Boolean     @default(false)
  isDeletedFor         String[] // User IDs array for "Delete For Me"
  voiceNoteUrl         String?
  scheduledFor         DateTime?
  parentId             String?
  parent               Message?    @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies              Message[]   @relation("MessageReplies")
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  attachments Attachment[]
  reactions   MessageReaction[]
  statuses    MessageStatus[]
  bookmarks   MessageBookmark[]
  poll        MessagePoll?

  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model MessageStatus {
  id          String    @id @default(uuid())
  messageId   String
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("DELIVERED")
  deliveredAt DateTime  @default(now())
  readAt      DateTime?

  @@unique([messageId, userId])
}

model File {
  id          String           @id @default(uuid())
  name        String
  url         String
  fileType    String
  size        Int
  uploaderId  String
  uploader    User             @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  version     Int              @default(1)
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  versions    FileVersion[]
  attachments Attachment[]
  taskAttach  TaskAttachment[]
  shares      FileShare[]
}

model FileVersion {
  id         String   @id @default(uuid())
  fileId     String
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  url        String
  version    Int
  uploaderId String
  createdAt  DateTime @default(now())
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  parentId    String?
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderHierarchy")
  createdById String
  files       File[]
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Announcement {
  id           String                @id @default(uuid())
  title        String
  content      String
  imageUrl     String?
  pdfUrl       String?
  priority     Priority              @default(NORMAL)
  isPinned     Boolean               @default(false)
  expiresAt    DateTime?
  createdById  String
  creator      User                  @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  viewsCount   Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  comments     AnnouncementComment[]
  likes        AnnouncementLike[]
}

model AnnouncementComment {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AnnouncementLike {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
}

model Task {
  id           String           @id @default(uuid())
  title        String
  description  String?
  priority     Priority         @default(NORMAL)
  status       TaskStatus       @default(TODO)
  dueDate      DateTime?
  assigneeId   String
  assignee     User             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  creatorId    String
  creator      User             @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progress     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  comments     TaskComment[]
  attachments  TaskAttachment[]
  history      TaskHistory[]
  subtasks     Subtask[]
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependentOn  TaskDependency[] @relation("TaskDependentOn")
  timeLogs     TaskTimeLog[]
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model Session {
  id                 String    @id @default(uuid())
  sessionId          String    @unique @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName         String?
  browser            String?
  operatingSystem    String?
  ipAddress          String?
  location           String?
  loginTime          DateTime  @default(now())
  lastActivity       DateTime  @default(now())
  expiresAt          DateTime
  refreshTokenHash   String?
  accessTokenVersion Int       @default(1)
  isRevoked          Boolean   @default(false)
  revokedReason      String?
  logoutTime         DateTime?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([isRevoked])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String
  createdAt DateTime @default(now())
}

model UserSettings {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme          String  @default("system")
  language       String  @default("en")
  pushEnabled    Boolean @default(true)
  emailEnabled   Boolean @default(true)
  desktopEnabled Boolean @default(true)
}

model CustomRole {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  parentId    String?
  parent      CustomRole?        @relation("RoleInheritance", fields: [parentId], references: [id], onDelete: SetNull)
  children    CustomRole[]       @relation("RoleInheritance")
  permissions CustomPermission[]
  users       User[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CustomPermission {
  id        String     @id @default(uuid())
  roleId    String
  role      CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String // Dashboard, Users, Groups, Announcements, Tasks, Files, Messages, Notifications, Reports, Admin, Analytics, Settings
  action    String // Create, Read, Update, Delete, Export, Import, Approve, Assign, Archive, Publish
  isEnabled Boolean    @default(true)

  @@unique([roleId, module, action])
}

model DashboardWidgetLayout {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey String // e.g. "tasks", "performance", "storage", etc.
  x         Int
  y         Int
  w         Int
  h         Int
  visible   Boolean @default(true)

  @@unique([userId, widgetKey])
}

model MessageBookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, messageId])
}

model MessagePoll {
  id        String              @id @default(uuid())
  messageId String              @unique
  message   Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  question  String
  options   MessagePollOption[]
  expiresAt DateTime?
}

model MessagePollOption {
  id     String            @id @default(uuid())
  pollId String
  poll   MessagePoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  MessagePollVote[]
}

model MessagePollVote {
  id       String            @id @default(uuid())
  optionId String
  option   MessagePollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

model FileShare {
  id         String    @id @default(uuid())
  fileId     String
  file       File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sharedById String
  sharedBy   User      @relation(fields: [sharedById], references: [id], onDelete: Cascade)
  accessKey  String    @unique
  expiresAt  DateTime?
  downloads  Int       @default(0)
  createdAt  DateTime  @default(now())
}

model Subtask {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TaskDependency {
  id              String @id @default(uuid())
  taskId          String
  task            Task   @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTaskId String
  dependsOnTask   Task   @relation("TaskDependentOn", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
}

model TaskTimeLog {
  id       String   @id @default(uuid())
  taskId   String
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  minutes  Int
  loggedAt DateTime @default(now())
}

model Experience {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  designation  String
  department   String?
  description  String?
  technologies String[]
  achievements String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
}

model Education {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  branch      String?
  startDate   DateTime?
  endDate     DateTime?
  grade       String?
}

model Certification {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  issuedBy       String
  issueDate      DateTime
  expiryDate     DateTime?
  credentialUrl  String?
  certificateUrl String?
}

model UserSkill {
  id         String  @id @default(uuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillName  String
  level      String // "BEGINNER", "INTERMEDIATE", "ADVANCED", "EXPERT"
  yearsOfExp Int     @default(0)
  isVerified Boolean @default(false)
  category   String? // e.g. "Frontend", "Backend"
  order      Int     @default(0)

  @@unique([userId, skillName])
}

model DeletedConversation {
  id        String   @id @default(uuid())
  userId    String
  contactId String?
  groupId   String?
  deletedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@unique([userId, groupId])
}
