datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum NotificationType {
  TASK_ASSIGNED
  MESSAGE
  ANNOUNCEMENT
  MENTION
  REMINDER
  SYSTEM
  MEETING
  GROUP_CREATED
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum GroupType {
  DEPARTMENT
  PROJECT
  CUSTOM
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  designation      String?
  bio              String?
  skills           String[]
  avatarUrl        String?
  role             Role                 @default(EMPLOYEE)
  status           String               @default("OFFLINE")
  location         String?
  isVerified       Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  
  employeeId       String?              @unique
  coverUrl         String?
  joiningDate      DateTime?
  employmentType   String?
  officeLocation   String?
  emergencyContact String?
  birthday         DateTime?
  timezone         String               @default("UTC")
  workingHours     String?
  managerId        String?
  manager          User?                @relation("OrgStructure", fields: [managerId], references: [id], onDelete: SetNull)
  directReports    User[]               @relation("OrgStructure")
  socialLinks      Json?
  lastSeen         DateTime?
  lastLoginAt      DateTime?

  experiences      Experience[]
  educations       Education[]
  certifications   Certification[]
  userSkills       UserSkill[]

  managedDepartments Department[]      @relation("DepartmentManager")
  departmentId     String?
  department       Department?          @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  
  teamMemberships  TeamMember[]
  groupMemberships GroupMember[]
  sentMessages     Message[]            @relation("MessageSender")
  receivedMessages Message[]            @relation("MessageReceiver")
  messageStatuses  MessageStatus[]
  messageReactions MessageReaction[]
  uploadedFiles    File[]
  createdGroups    Group[]              @relation("GroupCreator")
  wikiPages        WikiPage[]           @relation("WikiAuthor")
  wikiChanges      WikiVersion[]        @relation("WikiChangeAuthor")
  announcements    Announcement[]       @relation("AnnouncementCreator")
  comments         AnnouncementComment[]
  likes            AnnouncementLike[]
  announcementViews AnnouncementView[]
  assignedTasks    Task[]               @relation("TaskAssignee")
  createdTasks     Task[]               @relation("TaskCreator")
  taskComments     TaskComment[]
  taskHistories    TaskHistory[]
  notifications    Notification[]
  sessions         Session[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordReset[]
  emailVerifications EmailVerification[]
  auditLogs        AuditLog[]
  activityLogs     ActivityLog[]
  settings         UserSettings?
  customRoleId     String?
  customRole       CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  dashboardLayouts DashboardWidgetLayout[]
  messageBookmarks MessageBookmark[]
  messagePollVotes MessagePollVote[]
  fileShares       FileShare[]
  taskTimeLogs     TaskTimeLog[]
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)
  twoFactorBackupCodes String?
  loginAttempts    Int @default(0)
  lockoutUntil     DateTime?
  deletedConversations DeletedConversation[]
  hostedMeetings   Meeting[]
  meetingInvites   MeetingInvite[]

  leaveRequests        LeaveRequest[]
  leaveApprovals       LeaveRequest[]        @relation("LeaveApprover")
  leaveBalances        LeaveBalance[]
  attendances          Attendance[]
  expenseClaims        ExpenseClaim[]
  expenseApprovals     ExpenseClaim[]        @relation("ExpenseApprover")
  payslips             Payslip[]
  generatedPayslips    Payslip[]             @relation("PayslipGenerator")
  shiftAssignments     ShiftAssignment[]
  swapRequestsSent     ShiftSwapRequest[]    @relation("Requester")
  swapRequestsReceived ShiftSwapRequest[]    @relation("Assignee")
  swapRequestsApproved ShiftSwapRequest[]    @relation("SwapApprover")
  recognitionsSent     Recognition[]         @relation("Sender")
  recognitionsReceived Recognition[]         @relation("Receiver")
}

model Department {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String?
  managerId     String?
  manager       User?          @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees     User[]         @relation("DepartmentEmployees")
  teams         Team[]
  groups        Group[]
  announcements Announcement[]
  tasks         Task[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Team {
  id           String       @id @default(uuid())
  name         String
  description  String?
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  projects     Project[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status      String   @default("PLANNING")
  startDate   DateTime?
  endDate     DateTime?
  groups      Group[]
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id           String        @id @default(uuid())
  name         String
  description  String?
  type         GroupType     @default(CUSTOM)
  isBroadcast  Boolean       @default(false)
  avatarUrl    String?
  createdById  String
  creator      User          @relation("GroupCreator", fields: [createdById], references: [id])
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members      GroupMember[]
  messages     Message[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model Message {
  id                   String            @id @default(uuid())
  groupId              String?
  group                Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId             String
  sender               User              @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId           String?
  receiver             User?             @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content              String
  type                 MessageType       @default(TEXT)
  isEdited             Boolean           @default(false)
  isDeleted            Boolean           @default(false)
  isPinned             Boolean           @default(false)
  forwardedFromId      String?           // Tracks parent/source message when forwarded
  isDeletedForEveryone Boolean           @default(false)
  isDeletedFor         String[]          // User IDs array for "Delete For Me"
  voiceNoteUrl         String?
  scheduledFor         DateTime?
  parentId             String?
  parent               Message?          @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies              Message[]         @relation("MessageReplies")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  
  attachments          Attachment[]
  reactions            MessageReaction[]
  statuses             MessageStatus[]
  bookmarks            MessageBookmark[]
  poll                 MessagePoll?

  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model MessageStatus {
  id          String    @id @default(uuid())
  messageId   String
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("DELIVERED")
  deliveredAt DateTime  @default(now())
  readAt      DateTime?

  @@unique([messageId, userId])
}

model File {
  id           String        @id @default(uuid())
  name         String
  url          String
  fileType     String
  size         Int
  uploaderId   String
  uploader     User          @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  version      Int           @default(1)
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  versions     FileVersion[]
  attachments  Attachment[]
  taskAttach   TaskAttachment[]
  shares       FileShare[]
}

model FileVersion {
  id         String   @id @default(uuid())
  fileId     String
  file       File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  url        String
  version    Int
  uploaderId String
  createdAt  DateTime @default(now())
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  parentId    String?
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderHierarchy")
  createdById String
  files       File[]
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Announcement {
  id           String                @id @default(uuid())
  title        String
  content      String
  imageUrl     String?
  pdfUrl       String?
  priority     Priority              @default(NORMAL)
  isPinned     Boolean               @default(false)
  expiresAt    DateTime?
  createdById  String
  creator      User                  @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  viewsCount   Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  comments     AnnouncementComment[]
  likes        AnnouncementLike[]
  views        AnnouncementView[]
}

model AnnouncementComment {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AnnouncementLike {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
}

// Per-user read receipt for an announcement. Lets the author/admin see
// exactly who has (and hasn't) opened a given announcement — important for
// compliance-critical posts (policy changes, mandatory notices) where the
// aggregate `viewsCount` on Announcement alone isn't enough to know who
// still needs to be followed up with.
model AnnouncementView {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt       DateTime     @default(now())

  @@unique([announcementId, userId])
}

model Task {
  id                 String           @id @default(uuid())
  title              String
  description        String?
  priority           Priority         @default(NORMAL)
  status             TaskStatus       @default(TODO)
  dueDate            DateTime?
  assigneeId         String
  assignee           User             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  creatorId          String
  creator            User             @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  departmentId       String?
  department         Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progress           Int              @default(0)

  // Upgraded Task Management Fields
  estimatedHours     Float?
  labels             String[]         @default([])
  watcherIds         String[]         @default([])
  sprintName         String?
  milestoneName      String?
  isRecurring        Boolean          @default(false)
  recurrenceInterval String?          // 'daily', 'weekly', 'monthly'

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  comments           TaskComment[]
  attachments        TaskAttachment[]
  history            TaskHistory[]
  subtasks           Subtask[]
  dependencies       TaskDependency[] @relation("TaskDependencies")
  dependentOn        TaskDependency[] @relation("TaskDependentOn")
  timeLogs           TaskTimeLog[]
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileId    String
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// A meeting is created (SCHEDULED) the instant the host clicks "New meeting".
// This is the single source of truth for whether a code is real and whether
// it's currently live — the guest lobby screen checks this over REST *before*
// falling back to the socket for real-time "host just started" pushes, so a
// mistyped/expired code fails fast instead of spinning forever.
//
// scheduledFor is null for instant "start now" meetings, and set for meetings
// booked ahead of time via the scheduler — the calendar and "My Meetings" list
// both key off this field when it's present, falling back to createdAt otherwise.
model Meeting {
  id           String          @id @default(uuid())
  code         String          @unique
  title        String?
  hostId       String
  host         User            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  status       MeetingStatus   @default(SCHEDULED)
  createdAt    DateTime        @default(now())
  startedAt    DateTime?
  endedAt      DateTime?
  scheduledFor DateTime?
  durationMins Int?
  invites      MeetingInvite[]
}

enum MeetingInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model MeetingInvite {
  id        String              @id @default(uuid())
  meetingId String
  meeting   Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    MeetingInviteStatus @default(PENDING)
  createdAt DateTime            @default(now())

  @@unique([meetingId, userId])
}

model Session {
  id                 String    @id @default(uuid())
  sessionId          String    @unique @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName         String?
  browser            String?
  operatingSystem    String?
  ipAddress          String?
  location           String?
  loginTime          DateTime  @default(now())
  lastActivity       DateTime  @default(now())
  expiresAt          DateTime
  refreshTokenHash   String?
  accessTokenVersion Int       @default(1)
  isRevoked          Boolean   @default(false)
  revokedReason      String?
  logoutTime         DateTime?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([isRevoked])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String
  createdAt DateTime @default(now())
}

model UserSettings {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme          String  @default("system")
  language       String  @default("en")
  pushEnabled    Boolean @default(true)
  emailEnabled   Boolean @default(true)
  desktopEnabled Boolean @default(true)
}

// Singleton table (a single row) holding admin-controlled, per-feature
// switches for outbound notification emails. When a switch is off, no
// email is sent for that feature regardless of any user's personal email
// preference (UserSettings.emailEnabled) — the two checks are ANDed
// together in notification.service.ts.
model EmailFeatureSettings {
  id                  String   @id @default(uuid())
  newMessageEmail     Boolean  @default(true) // direct (1:1) messages
  groupMessageEmail   Boolean  @default(true) // group messages & mentions
  groupCreationEmail  Boolean  @default(true) // added to a new group
  taskAssignedEmail   Boolean  @default(true)
  taskUpdatedEmail    Boolean  @default(true)
  announcementEmail   Boolean  @default(true)
  meetingInviteEmail  Boolean  @default(true)
  fileSharedEmail     Boolean  @default(true)
  updatedAt           DateTime @updatedAt
  updatedById         String?
}

// Singleton table (a single row) holding org-wide branding and configuration
// values. Any code that needs the company name, logo, support contact, etc.
// should read from here (via organization.service.ts on the backend, or the
// useOrganizationSettings hook on the frontend) instead of hardcoding a
// literal string — so a change made once by the admin propagates everywhere
// automatically (sidebar, auth pages, emails, landing page, file watermark).
model OrganizationSettings {
  id                   String   @id @default(uuid())
  orgName              String   @default("ConnectHub")
  tagline              String   @default("Enterprise Communication & Collaboration Platform")
  logoUrl              String?
  faviconUrl           String?
  primaryColor         String   @default("#4f46e5")
  supportEmail         String?
  website              String?
  address              String?
  defaultWatermarkText String   @default("ConnectHub CONFIDENTIAL")
  defaultTimezone      String   @default("UTC")
  updatedAt            DateTime @updatedAt
  updatedById          String?
}

model CustomRole {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  parentId    String?
  parent      CustomRole?        @relation("RoleInheritance", fields: [parentId], references: [id], onDelete: SetNull)
  children    CustomRole[]       @relation("RoleInheritance")
  permissions CustomPermission[]
  users       User[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CustomPermission {
  id        String     @id @default(uuid())
  roleId    String
  role      CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String     // Dashboard, Users, Groups, Announcements, Tasks, Files, Messages, Notifications, Reports, Admin, Analytics, Settings
  action    String     // Create, Read, Update, Delete, Export, Import, Approve, Assign, Archive, Publish
  isEnabled Boolean    @default(true)

  @@unique([roleId, module, action])
}

model DashboardWidgetLayout {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey String   // e.g. "tasks", "performance", "storage", etc.
  x         Int
  y         Int
  w         Int
  h         Int
  visible   Boolean  @default(true)

  @@unique([userId, widgetKey])
}

model MessageBookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, messageId])
}

model MessagePoll {
  id        String              @id @default(uuid())
  messageId String              @unique
  message   Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  question  String
  options   MessagePollOption[]
  expiresAt DateTime?
}

model MessagePollOption {
  id        String            @id @default(uuid())
  pollId    String
  poll      MessagePoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  votes     MessagePollVote[]
}

model MessagePollVote {
  id       String            @id @default(uuid())
  optionId String
  option   MessagePollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

model FileShare {
  id                 String    @id @default(uuid())
  fileId             String
  file               File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sharedById         String
  sharedBy           User      @relation(fields: [sharedById], references: [id], onDelete: Cascade)
  accessKey          String    @unique
  expiresAt          DateTime?
  downloads          Int       @default(0)
  createdAt          DateTime  @default(now())
  // Empty = "anyone with the link" (public). Non-empty = only these user ids may
  // access it — enforced in accessSharedFile, not just cosmetic.
  restrictedToUserIds String[] @default([])
}

model Subtask {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TaskDependency {
  id              String @id @default(uuid())
  taskId          String
  task            Task   @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTaskId String
  dependsOnTask   Task   @relation("TaskDependentOn", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
}

model TaskTimeLog {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  minutes   Int
  loggedAt  DateTime @default(now())
}

model Experience {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      String
  designation  String
  department   String?
  description  String?
  technologies String[]
  achievements String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
}

model Education {
  id          String    @id @default(uuid())
  userId      String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  branch      String?
  startDate   DateTime?
  endDate     DateTime?
  grade       String?
}

model Certification {
  id             String    @id @default(uuid())
  userId       String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  issuedBy       String
  issueDate      DateTime
  expiryDate     DateTime?
  credentialUrl  String?
  certificateUrl String?
}

model UserSkill {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillName  String
  level      String    // "BEGINNER", "INTERMEDIATE", "ADVANCED", "EXPERT"
  yearsOfExp Int       @default(0)
  isVerified Boolean   @default(false)
  category   String?   // e.g. "Frontend", "Backend"
  order      Int       @default(0)

  @@unique([userId, skillName])
}

model DeletedConversation {
  id          String   @id @default(uuid())
  userId      String
  contactId   String?
  groupId     String?
  deletedAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@unique([userId, groupId])
}

model Invitation {
  id          String   @id @default(uuid())
  email       String   @unique
  role        String   @default("EMPLOYEE")
  token       String   @unique
  invitedById String
  isUsed      Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model WikiPage {
  id          String        @id @default(uuid())
  title       String
  content     String
  category    String        @default("General")
  authorId    String
  author      User          @relation("WikiAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  versions    WikiVersion[] @relation("WikiPageVersions")
}

model WikiVersion {
  id          String   @id @default(uuid())
  pageId      String
  page        WikiPage @relation("WikiPageVersions", fields: [pageId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  content     String
  changedById String
  changedBy   User     @relation("WikiChangeAuthor", fields: [changedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  trigger     String   // e.g. "TASK_COMPLETED", "EMPLOYEE_JOINED", "DOCUMENT_UPLOADED"
  action      String   // e.g. "NOTIFY_MANAGER", "ASSIGN_ONBOARDING_TASKS", "NOTIFY_TEAM"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayslipStatus {
  DRAFT
  PAID
  UNPAID
}

enum SwapStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType     String       // e.g., ANNUAL, SICK, CASUAL, UNPAID
  startDate     DateTime
  endDate       DateTime
  reason        String
  status        LeaveStatus  @default(PENDING)
  approvedById  String?
  approvedBy    User?        @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  managerNotes  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model LeaveBalance {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType     String       // e.g., ANNUAL, SICK, CASUAL, UNPAID
  total         Float
  used          Float        @default(0)
  year          Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([userId, leaveType, year])
}

model Attendance {
  id            String             @id @default(uuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime           // Normalized to local date (00:00:00)
  clockIn       DateTime
  clockOut      DateTime?
  status        AttendanceStatus   @default(PRESENT)
  ipAddress     String?
  location      String?
  notes         String?
  breaks        AttendanceBreak[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AttendanceBreak {
  id            String       @id @default(uuid())
  attendanceId  String
  attendance    Attendance   @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  startTime     DateTime
  endTime       DateTime?
}

model Holiday {
  id            String       @id @default(uuid())
  name          String
  date          DateTime     @unique
  description   String?
  isMandatory   Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ExpenseClaim {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  category      String       // e.g., TRAVEL, MEALS, EQUIPMENT, UTILITIES, OTHERS
  amount        Float
  currency      String       @default("USD")
  description   String?
  receiptUrl    String?
  status        ExpenseStatus @default(PENDING)
  approvedById  String?
  approvedBy    User?        @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  managerNotes  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Payslip {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  basicSalary   Float
  allowances    Float        @default(0)
  deductions    Float        @default(0)
  netSalary     Float
  status        PayslipStatus @default(UNPAID)
  generatedById String
  generatedBy   User         @relation("PayslipGenerator", fields: [generatedById], references: [id], onDelete: Cascade)
  fileUrl       String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Shift {
  id            String             @id @default(uuid())
  name          String
  startTime     String             // e.g. "09:00"
  endTime       String             // e.g. "17:00"
  color         String?            // CSS or hex code color
  description   String?
  assignments   ShiftAssignment[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model ShiftAssignment {
  id                  String             @id @default(uuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId             String
  shift               Shift              @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  startDate           DateTime
  endDate             DateTime
  requesterSwapRequests ShiftSwapRequest[] @relation("RequesterAssignment")
  assigneeSwapRequests ShiftSwapRequest[]  @relation("AssigneeAssignment")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model ShiftSwapRequest {
  id                    String           @id @default(uuid())
  requesterId           String
  requester             User             @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  assigneeId            String
  assignee              User             @relation("Assignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  requesterAssignmentId String
  requesterAssignment   ShiftAssignment  @relation("RequesterAssignment", fields: [requesterAssignmentId], references: [id], onDelete: Cascade)
  assigneeAssignmentId  String
  assigneeAssignment    ShiftAssignment  @relation("AssigneeAssignment", fields: [assigneeAssignmentId], references: [id], onDelete: Cascade)
  status                SwapStatus       @default(PENDING)
  approvedById          String?
  approvedBy            User?            @relation("SwapApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Recognition {
  id            String       @id @default(uuid())
  senderId      String
  sender        User         @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User         @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  badge         String       // e.g., TEAM_PLAYER, INNOVATOR, CUSTOMER_CHAMPION, ROCKSTAR
  message       String
  createdAt     DateTime     @default(now())
}
