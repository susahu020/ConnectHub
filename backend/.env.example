# Server configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
# For PostgreSQL (local or Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/connecthub?schema=public"

# Redis (local or Upstash)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="super-secret-access-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary (Optional, falls back to local storage)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMTP Mail Server (Optional, falls back to Ethereal account mock)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@connecthub.com"
